// 1. WebRTC Camera Component for Real-time Verification
function CameraCapture({ onCapture, t }) {
  const videoRef = useRef(null);
  const canvasRef = useRef(null);
  const [stream, setStream] = useState(null);
  const [error, setError] = useState(false);
  const [image, setImage] = useState(null);

  useEffect(() => {
    startCamera();
    return stopCamera;
  }, []);

  const startCamera = async () => {
    setError(false);
    try {
      const s = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
      setStream(s);
      if(videoRef.current) videoRef.current.srcObject = s;
    } catch (err) {
      console.warn("Camera access denied or unavailable", err);
      setError(true);
    }
  };

  const stopCamera = () => {
    if(stream) {
      stream.getTracks().forEach(t => t.stop());
      setStream(null);
    }
  };

  const handleCapture = () => {
    if(error) {
      // Fallback for mock environment without camera permissions
      setImage("https://via.placeholder.com/300x200?text=Mock+Verified+Photo");
      onCapture("mock_image_data");
      return;
    }
    const canvas = canvasRef.current;
    const video = videoRef.current;
    canvas.width = video.videoWidth;
    canvas.height = video.videoHeight;
    canvas.getContext('2d').drawImage(video, 0, 0);
    const dataUrl = canvas.toDataURL('image/jpeg');
    setImage(dataUrl);
    onCapture(dataUrl);
    stopCamera();
  };

  const handleRetake = () => {
    setImage(null);
    onCapture(null);
    startCamera();
  };

  if (image) {
    return (
      <div className="relative rounded-xl overflow-hidden border-2 border-green-500 shadow-sm">
        <img src={image} alt="Captured" className="w-full h-48 object-cover" />
        <div className="absolute top-2 right-2 bg-green-500 text-white text-xs px-2 py-1 rounded-md flex items-center gap-1 font-bold">
          <CheckCircle size={12} /> Verified
        </div>
        <button type="button" onClick={handleRetake} className="absolute bottom-2 right-2 bg-gray-900/70 text-white px-3 py-1 rounded-lg text-sm flex items-center gap-2">
          <Camera size={14} /> {t('retake_photo')}
        </button>
      </div>
    );
  }

  return (
    <div className="relative rounded-xl overflow-hidden bg-black flex flex-col items-center justify-center h-48">
      {error ? (
        <div className="text-gray-400 text-center p-4">
          <ImageIcon className="mx-auto mb-2 opacity-50" size={32}/>
          <p className="text-sm">Camera unavailable. Click capture for mock photo.</p>
        </div>
      ) : (
        <video ref={videoRef} autoPlay playsInline className="w-full h-full object-cover opacity-80" />
      )}
      <button type="button" onClick={handleCapture} className="absolute bottom-4 bg-white text-gray-900 px-4 py-2 rounded-full font-bold shadow-lg flex items-center gap-2">
        <Camera size={18} /> {t('take_photo')}
      </button>
      <canvas ref={canvasRef} className="hidden" />
    </div>
  );
}

