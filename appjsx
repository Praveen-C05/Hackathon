function SidebarItem({ icon, label, active, onClick }) { return <button onClick={onClick} className={`flex items-center gap-3 w-full p-4 rounded-xl transition-colors font-medium text-lg ${active ? 'bg-green-700 text-white font-bold' : 'text-green-100 hover:bg-green-700/50'}`}>{icon} <span>{label}</span></button>; }