function LoginScreen({ t, setUser, setPage, lang, setLang }) {
  const [phone, setPhone] = useState('');
  const [step, setStep] = useState(1);
  const [otp, setOtp] = useState('');
  const [role, setRole] = useState('farmer');

  return (
    <div className="flex flex-col items-center justify-center min-h-[80vh]">
      <div className="w-full max-w-md bg-white p-8 rounded-3xl shadow-xl border border-gray-100">
        <div className="flex justify-center mb-6"><div className="bg-green-100 p-4 rounded-full"><Leaf className="w-12 h-12 text-green-600" /></div></div>
        <h1 className="text-3xl font-black text-center text-green-800 tracking-tight mb-2">{t('appTitle')}</h1>
        <p className="text-center text-gray-500 mb-6">{t('login_title')}</p>

        <div className="flex justify-center gap-2 mb-8">
          {['en', 'hi', 'kn'].map(l => (
            <button key={l} onClick={()=>setLang(l)} className={`px-4 py-1 rounded-full text-sm font-medium ${lang === l ? 'bg-green-600 text-white' : 'bg-gray-100 text-gray-600'}`}>
              {l === 'en' ? 'English' : l === 'hi' ? 'हिंदी' : 'ಕನ್ನಡ'}
            </button>
          ))}
        </div>

        {step === 1 ? (
          <form onSubmit={e => { e.preventDefault(); if(phone.length >= 10) setStep(2); }} className="space-y-4">
            <div className="flex gap-2">
              <button type="button" onClick={()=>setRole('farmer')} className={`flex-1 py-3 rounded-xl border-2 font-bold ${role==='farmer' ? 'border-green-600 bg-green-50 text-green-700' : 'border-gray-200 text-gray-500'}`}>{t('role_farmer')}</button>
              <button type="button" onClick={()=>setRole('buyer')} className={`flex-1 py-3 rounded-xl border-2 font-bold ${role==='buyer' ? 'border-blue-600 bg-blue-50 text-blue-700' : 'border-gray-200 text-gray-500'}`}>{t('role_buyer')}</button>
            </div>
            <input type="tel" required placeholder="Enter Mobile Number" value={phone} onChange={e=>setPhone(e.target.value)} className="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl text-lg outline-none focus:ring-2 focus:ring-green-500" />
            <button type="submit" className="w-full py-4 bg-green-600 text-white rounded-xl font-bold text-lg shadow-lg shadow-green-200">{t('send_otp')}</button>
          </form>
        ) : (
          <form onSubmit={e => { e.preventDefault(); if(otp==='1234') { setUser({ phone, role }); setPage('ask'); } else alert("Try 1234"); }} className="space-y-4">
            <p className="text-center text-sm text-green-600 font-medium">{t('mock_otp_msg')}</p>
            <input type="text" required placeholder="OTP" value={otp} onChange={e=>setOtp(e.target.value)} maxLength="4" className="w-full p-4 bg-gray-50 border border-gray-200 rounded-xl text-center text-2xl tracking-widest font-bold outline-none focus:ring-2 focus:ring-green-500" />
            <button type="submit" className="w-full py-4 bg-green-600 text-white rounded-xl font-bold text-lg shadow-lg">{t('verify_otp')}</button>
          </form>
        )}
      </div>
    </div>
  );
}

