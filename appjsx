  const [crops, setCrops] = useState(INITIAL_CROPS);
  const [orders, setOrders] = useState([]);
  const [equipment, setEquipment] = useState(INITIAL_EQUIPMENT);
  
  // Shared Navigation State for Bot Routing
  const [marketTab, setMarketTab] = useState('browse');
  const [equipTab, setEquipTab] = useState('rent');

  const t = (key) => i18n[lang][key] || key;

  // AI Helper API
  const callGeminiAI = async (prompt) => {
    const apiKey = ""; // Set environment API key here if needed
    if (!apiKey) {
      return new Promise(resolve => setTimeout(() => resolve("This is a simulated AI response. Neem oil is great for pests! 🌱"), 1000));
    }
    try {
      const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
        method: "POST", headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ contents: [{ parts: [{ text: `Act as KrishiMitra. Keep answers very short. User asked: ${prompt}` }] }] })
      });
      const data = await response.json();
      return data.candidates[0].content.parts[0].text;
    } catch (e) {
      return "Network issue. Please try again.";
    }
  };

  const renderPage = () => {
    if (!user) return <LoginScreen t={t} setUser={setUser} setPage={setCurrentPage} lang={lang} setLang={setLang} />;
    
    switch (currentPage) {
      case 'home': return <Dashboard t={t} role={user.role} />;
      case 'market': return <Marketplace t={t} crops={crops} setCrops={setCrops} role={user.role} addOrder={(o) => setOrders([o, ...orders])} setPage={setCurrentPage} tab={marketTab} setTab={setMarketTab} />;
      case 'orders': return <Orders t={t} orders={orders} setOrders={setOrders} role={user.role} />;
      case 'equip': return <Equipment t={t} equipment={equipment} setEquipment={setEquipment} tab={equipTab} setTab={setEquipTab} />;
      case 'ask': return <ActionBot t={t} lang={lang} callAI={callGeminiAI} setPage={setCurrentPage} setMarketTab={setMarketTab} setEquipTab={setEquipTab} />;
      case 'learn': return <LearningHub t={t} />;
      default: return <Dashboard t={t} role={user.role} />;
    }
  };

  return (
    <div className="min-h-screen bg-gray-50 text-gray-900 font-sans pb-20 md:pb-0 md:flex">
      {/* Desktop Sidebar */}
      {user && (
        <aside className="hidden md:flex flex-col w-64 bg-green-800 text-white min-h-screen sticky top-0">
          <div className="p-4 text-2xl font-bold border-b border-green-700 flex items-center gap-2">
            <Leaf /> {t('appTitle')}
          </div>
          <nav className="flex-1 p-4 space-y-2">
            <SidebarItem icon={<Home/>} label={t('nav_home')} active={currentPage==='home'} onClick={()=>setCurrentPage('home')}/>
            <SidebarItem icon={<ShoppingCart/>} label={t('nav_market')} active={currentPage==='market'} onClick={()=>setCurrentPage('market')}/>
            <SidebarItem icon={<Truck/>} label={t('nav_orders')} active={currentPage==='orders'} onClick={()=>setCurrentPage('orders')}/>
            <SidebarItem icon={<Tractor/>} label={t('nav_equip')} active={currentPage==='equip'} onClick={()=>setCurrentPage('equip')}/>
            <SidebarItem icon={<MessageCircle/>} label={t('nav_ask')} active={currentPage==='ask'} onClick={()=>setCurrentPage('ask')}/>
            <SidebarItem icon={<BookOpen/>} label={t('nav_learn')} active={currentPage==='learn'} onClick={()=>setCurrentPage('learn')}/>
          </nav>
        </aside>
      )}

      {/* Main Content Area */}
      <main className="flex-1 w-full relative">
        {user && (
          <header className="bg-white shadow-sm p-4 flex justify-between items-center sticky top-0 z-10">
            <div className="md:hidden font-bold text-green-700 flex items-center gap-2">
              <Leaf size={24} /> {t('appTitle')}
            </div>
            <div className="hidden md:block font-semibold text-gray-600">Welcome, {user.phone} ({user.role})</div>
            <div className="flex items-center gap-4">
              <select value={lang} onChange={(e) => setLang(e.target.value)} className="bg-gray-100 border-none text-sm rounded-lg p-2 focus:ring-green-500 cursor-pointer">
